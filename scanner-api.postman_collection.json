          "description": "Returns URL scan cache statistics — cache size, hit rate, and TTL configuration for the URL analysis result cache.",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/status/url-cache",
              "host": ["{{base_url}}"],
              "path": ["api", "status", "url-cache"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
