# Email Scanner API Configuration Template
# Copy this file to .env and replace ## placeholders with actual values

# Google Safe Browsing API Key - Get from https://developers.google.com/safe-browsing/v4/get-started
# Enable "Safe Browsing API" in Google Cloud Console, then create an API key
GOOGLE_SAFE_BROWSING_KEY=##

# API Authentication Key - Generate a secure random string
API_KEY=##

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# External API Timeout (seconds)
EXTERNAL_API_TIMEOUT=30

# ML Ensemble mode: false = LR only (~50MB), true = full ensemble LR+XGB+LGBM (~200MB)
FULL_ENSEMBLE=false
